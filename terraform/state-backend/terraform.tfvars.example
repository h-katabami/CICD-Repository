aws_region        = "ap-northeast-1"
state_bucket_name_dev  = "terraform-state-dev-<account-id>"
state_bucket_name_prod = "terraform-state-prod-<account-id>"

github_org  = "<github-org-or-user>"
github_repo = "twilio-flow-custom-parts-kawagoe-city"

enabled_environments = ["dev"]

deploy_role_name_dev  = "gha-terraform-deploy-dev"
deploy_role_name_prod = "gha-terraform-deploy-prod"
